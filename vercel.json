{
  "version": 2,
  "installCommand": "npm install && npx prisma generate --schema=system/prisma/schema.prisma",
  "builds": [
    {
      "src": "api/[...route].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route].js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}