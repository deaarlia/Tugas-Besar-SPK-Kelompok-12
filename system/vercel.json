{
  "version": 2,
  "builds": [
    {
      "src": "api/[...route].js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route].js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}